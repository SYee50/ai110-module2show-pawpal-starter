classDiagram
    %% PawPal+ class diagram
    %% Data flows Owner -> Pet(s) -> Task(s); Scheduler reads the Owner to build a daily plan.

    class Owner {
        +str name
        +str start_time
        +str end_time
        +list~Pet~ pets
        +add_pet(pet) void
        +remove_pet(name) bool
        +find_pet(name) Pet
        +available_minutes() int
        +get_all_tasks() list~Task~
    }

    class Pet {
        +str name
        +str species
        +str breed
        +Owner owner
        +list~Task~ tasks
        +add_task(task) void
        +remove_task(description) bool
        +get_tasks() list~Task~
        +header() str
    }

    class Task {
        +str description
        +int duration_minutes
        +str frequency
        +bool completed
        +str time
        +date due_date
        +Pet pet
        +mark_complete() Task
        +next_occurrence() Task
        +__str__() str
    }

    class Scheduler {
        +Owner owner
        +sort_by_time(tasks) list~Task~
        +filter_tasks(completed, pet_name) list~Task~
        +detect_conflicts() list~str~
        +build_schedule() dict
        +get_pet_schedule(pet) list
        +format_pet_schedule(pet) str
        +format_all_schedules() str
    }

    Owner "1" *-- "many" Pet : has
    Pet "1" *-- "many" Task : has
    Pet "many" --> "1" Owner : back-ref (owner)
    Task "many" --> "1" Pet : back-ref (pet)
    Scheduler "1" --> "1" Owner : reads
